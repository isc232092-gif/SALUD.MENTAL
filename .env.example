# Copia este archivo como .env y llena los datos reales de Supabase (PostgreSQL).
PORT=3000
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres
# O la cadena del pooler de transacciones de Supabase:
# DATABASE_URL=postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
